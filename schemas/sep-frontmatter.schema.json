{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/spore-lang/spore-evolution/schemas/sep-frontmatter.schema.json",
  "title": "SEP front matter",
  "type": "object",
  "required": [
    "sep",
    "title",
    "status",
    "type",
    "authors",
    "created",
    "requires",
    "discussion",
    "pr",
    "superseded_by"
  ],
  "additionalProperties": false,
  "properties": {
    "sep": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "Draft",
        "Accepted",
        "Rejected",
        "Withdrawn",
        "Superseded"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "Standards Track",
        "Process",
        "Informational"
      ]
    },
    "authors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "requires": {
      "type": "array",
      "items": {
        "type": [
          "integer",
          "string"
        ]
      }
    },
    "discussion": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "pr": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "superseded_by": {
      "type": [
        "integer",
        "string",
        "null"
      ]
    }
  }
}
